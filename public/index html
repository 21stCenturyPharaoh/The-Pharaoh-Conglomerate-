<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Hermes Command Console</title>
</head>
<body>

<h1>Hermes Agent Console</h1>

<select id="agent">
  <option>Alpha-Hesed</option>
  <option>Alpha-Nefertari-Scribe</option>
  <option>Alpha-Archangel-Poet</option>
  <option>Alpha-Watcher</option>
</select>

<br><br>

<input
  id="msg"
  type="text"
  placeholder="Enter your message"
  style="width:300px;"
>

<button onclick="runHermes()">
  Send
</button>

<pre id="output"></pre>

<script>
async function runHermes() {

  const agentName =
    document.getElementById("agent").value;

  const message =
    document.getElementById("msg").value;

  const response =
    await fetch("/.netlify/functions/hermes", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        agentName,
        message
      })
    });

  const data = await response.json();

  document.getElementById("output").textContent =
    data.reply;
}
</script>

</body>
</html>
